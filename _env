MONGOUSERNAME=example
MONGOPASSWORD=CHANGE_TO_RANDOM_STRING
POSTGREUSER=example
POSTGREPASSWORD=CHANGE_TO_RANDOM_STRING

MAP_DEFAULT_LATITUDE=35.655090799599584
MAP_DEFAULT_LONGITUDE=139.79447397791276
MAP_DEFAULT_ZOOM=15
DEFAULT_ZOOM_FOR_COLLECTION_RANGE=20
DATASET_LIST_BY=menu

# Google認証を利用しない場合、docker上のコンテナから到達可能なホストOSのIPアドレスで `YOUR_IP_ADDRESS` を置換します。
# 127.0.0.0やlocalhostでは動作しません
HOST_URL=http://YOUR_IP_ADDRESS:8080

# Google認証を使用する場合、ngrokから得たURLに置換
# HOST_URL=https://xxxx-xxx-xxx-xxx-xxx.ngrok-free.app 

KEYCLOAK_ADMIN=example
KEYCLOAK_ADMIN_PASSWORD=CHANGE_TO_RANDOM_STRING
KC_HOSTNAME_URL=${HOST_URL}
KC_HOSTNAME_ADMIN_URL=${HOST_URL}

GENERAL_USER_KEYCLOAK_CLIENT_ID=general-user-client
GENERAL_USER_KEYCLOAK_CLIENT_SECRET=COPY_KEYCLOAK_CLIENT_SECRET
ADMIN_KEYCLOAK_CLIENT_ID=admin-client
ADMIN_KEYCLOAK_CLIENT_SECRET=COPY_KEYCLOAK_CLIENT_SECRET
KEYCLOAK_CLIENT_ISSUER=${HOST_URL}/realms/oasismap

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_TO_RANDOM_STRING

BACKEND_URL=http://localhost:4000

REVERSE_GEOCODING_URL=https://nominatim.openstreetmap.org/reverse

# Google認証を使用する場合、GoogleのクライアントIDとクライアントシークレットを設定
# GOOGLE_CLIENT_ID=YOUR_GOOGLE_IDP_CLIENT_ID
# GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_IDP_CLIENT_SECRET

# 参考: https://dev.classmethod.jp/articles/playwright-e2e-otp-mfa/
# MFAを設定していない場合は空にしておく
# GOOGLE_MFA_SECRET_KEY=CHANGE_TO_MFA_SECRET_KEY   # 参考サイトより長くてKOCPで始まるやつだった
# GOOGLE_EMAIL=CHANGE_TO_EMAIL_ADDRESS
# GOOGLE_PASSWORD='CHANGE_TO_PASSWORD'  # 特殊記号がある場合はシングルクォートで囲む方が安全か

# Cluster configuration
NEXT_PUBLIC_MAX_CLUSTER_RADIUS=200
USE_MOCK_DATA=true
