# terraform.tfvars にコピーして実値を設定すること。terraform.tfvars はコミットしないこと。
# バックエンド: terraform init -backend-config=config.azurerm.tfbackend を実行し、
# config.azurerm.tfbackend に state 保存先の resource_group_name と storage_account_name を記載する
# （または -backend-config で個別指定）。

resource_group_name = "YOUR_RESOURCE_GROUP_NAME"
prefix              = "oasismap"
location            = "japanwest"

# VNet
vnet_address_prefix  = "10.0.0.0/16"
subnet_dmz_prefix    = "10.0.0.0/24"
subnet_app_prefix    = "10.0.1.0/24"
subnet_db_prefix     = "10.0.2.0/24"
# Application Gateway 専用サブネット（app 層の AGW が使用。variables.tf の既定と同じ）
subnet_agw_prefix    = "10.0.3.0/26"

# Cosmos DB
mongo_api_version       = "6.0"
cosmosdb_database_name  = "oriondb"

# PostgreSQL（パスワード: tfvars で設定するか、作成後にローテーションして Key Vault に保存）
postgres_admin_login          = "postgres"
postgres_admin_password       = "CHANGE_ME_PLACEHOLDER"
postgres_sku_name             = "GP_Standard_D2ds_v4"
postgres_storage_mb            = 32768
postgres_version              = "16"
postgres_backup_retention_days = 7
postgres_geo_redundant_backup  = "Disabled"

# Log Analytics
log_analytics_sku                 = "PerGB2018"
log_analytics_retention_in_days   = 30

# Key Vault
key_vault_sku = "standard"

# モニタリング
# alert_mail_dest_address = "alert@example.com"
