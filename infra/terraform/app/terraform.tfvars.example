# terraform.tfvars にコピーして実値を設定すること。terraform.tfvars はコミットしないこと。
# バックエンド: terraform init -backend-config=config.azurerm.tfbackend。
# config.azurerm.tfbackend に resource_group_name と storage_account_name を記載する。

backend_resource_group_name   = "YOUR_TF_STATE_RESOURCE_GROUP_NAME"
backend_storage_account_name  = "YOUR_TF_STATE_STORAGE_ACCOUNT_NAME"

prefix   = "oasismap"
# Azure リージョンの識別名（platform と一致させる）
location = "japanwest"

app_service_plan_sku      = "P1v3"
app_frontend_name            = "YOUR_UNIQUE_FRONTEND_APP_NAME"
app_frontend_nextauth_secret = "CHANGE_TO_RANDOM_STRING_FOR_NEXTAUTH_SECRET"
app_backend_name             = "YOUR_UNIQUE_BACKEND_APP_NAME"
app_keycloak_name         = "YOUR_UNIQUE_KEYCLOAK_APP_NAME"

# Keycloak 管理者（keycloak-realm 層の app_keycloak_* と同一の値にする）
app_keycloak_admin          = "YOUR_KEYCLOAK_ADMIN_USERNAME"
app_keycloak_admin_password = "YOUR_KEYCLOAK_ADMIN_PASSWORD"

# Let's Encrypt（acme_registration_email は必須）
acme_registration_email = "your.acme.email@example.com"
# 本番用のACMEサーバーURL
acme_server_url       = "https://acme-v02.api.letsencrypt.org/directory"
# 検証用のACMEサーバーURL（ブラウザで信頼されないことに注意）
# acme_server_url             = "https://acme-staging-v02.api.letsencrypt.org/directory"

aci_orion_image_tag  = "orion:latest"
aci_cygnus_image_tag = "cygnus:latest"
aci_mongo_cli_image_tag = "mongo-cli:latest"
aci_postgres_cli_image_tag = "postgres-cli:latest"

agw_sku           = "WAF_v2"
agw_min_capacity  = 1
agw_max_capacity  = 2
agw_waf_enabled   = "Enabled"
agw_waf_mode      = "Prevention"

# 参加同意書・フロント表示（README §6.1.2。任意で上書き）
# terms_municipality_name = "【自治体名】"
# terms_date              = "yyyy年mm月dd日"
# terms_title_suffix      = "（雛形）"

